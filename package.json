{
  "name": "zubanls",
  "displayName": "ZubanLS",
  "description": "A very fast, low-memory Python Language Server built in Rust",
  "version": "0.2.2",
  "engines": {
    "vscode": "^1.74.0"
  },
  "activationEvents": [
    "onDebugInitialConfigurations",
    "onLanguage:python",
    "onNotebook:jupyter-notebook",
    "onCommand:python.copilotSetupTests",
    "workspaceContains:setup.py",
    "workspaceContains:pyproject.toml",
    "workspaceContains:pylock.toml",
    "workspaceContains:requirements.txt",
    "workspaceContains:manage.py",
    "workspaceContains:app.py",
    "workspaceContains:.venv",
    "workspaceContains:.conda",
    "workspaceContains:Pipfile",
    "workspaceContains:mspythonconfig.json"
  ],
  "author": {
    "name": "David Halter"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "keywords": [
    "python",
    "type",
    "typecheck",
    "lint",
    "analysis",
    "static analysis"
  ],
  "icon": "brandmark.png",
  "galleryBanner": {
    "color": "#301f2f",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zubanls/vscode-zubanls.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/zubanls/vscode-zubanls/issues",
    "email": "info@zubanls.com"
  },
  "homepage": "https://zubanls.com",
  "publisher": "zuban",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": {
      "supported": "limited",
      "description": "In virtual workspaces, resolving imports might not be possible."
    }
  },
  "contributes": {
    "languages": [
      {
        "id": "python",
        "aliases": [
          "Python"
        ],
        "extensions": [
          ".py",
          ".pyi"
        ]
      }
    ],
    "commands": [
      {
        "title": "Restart Zuban",
        "category": "zuban",
        "command": "zuban.restart"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "python",
        "scopes": {
          "variable.readonly": [
            "variable.other.constant.python"
          ]
        }
      }
    ],
    "configurationDefaults": {
      "basedpyright.disableLanguageServices": true,
      "cursorpyright.disableLanguageServices": true,
      "windsurfPyright.disableLanguageServices": true,
      "pyrefly.disableLanguageServices": true,
      "editor.semanticTokenColorCustomizations": {
        "rules": {
          "variable.readonly:python": "#4EC9B0"
        }
      }
    },
    "configuration": {
      "properties": {
        "zuban.executablePath": {
          "type": "string",
          "default": "",
          "markdownDescription": "The path to the binary used for the LSP",
          "scope": "machine-overridable"
        },
        "python.zuban.disableLanguageServices": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "If true, Zuban will not provide other IDE services like completions, hover, definition, etc. To control type errors, see `python.zuban.typeCheckingMode`.",
          "scope": "resource"
        },
        "python.zuban.typeCheckingMode": {
          "type": "string",
          "markdownDescription": "Default [mode](https://docs.zubanls.com/en/latest/usage.html#modes) to use if there is no explicit Zuban config in `pyproject.toml`. The default `auto` lets Zuban automatically choose the mode depending on config files.",
          "default": "auto",
          "enum": [
            "auto",
            "off",
            "default",
            "mypy"
          ],
          "scope": "resource"
        },
        "zuban.trace.server": {
          "type": "string",
          "markdownDescription": "Set to `verbose` to enable LSP trace in the console",
          "default": "off",
          "enum": [
            "off",
            "verbose"
          ]
        },
        "python.zuban.diagnosticMode": {
          "type": "string",
          "default": "open-files-only",
          "markdownDescription": "Controls the scope of Zuban's diagnostic analysis. When set to `open-files-only`, diagnostics are only provided for files that are currently open in the editor. When set to `workspace`, diagnostics are computed and published for all files in the workspace, which can be very slow for big projects.",
          "enum": [
            "open-files-only",
            "workspace"
          ],
          "scope": "resource"
        },
        "zuban.loggingVerbosity": {
          "type": "string",
          "default": "error",
          "enum": [
            "error",
            "warning",
            "info",
            "debug",
            "off"
          ],
          "markdownDescription": "The value is passed to the `ZUBAN_LOG` environment variable.",
          "scope": "machine-overridable"
        }
      }
    }
  },
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "check-format": "biome check ./src",
    "auto-format": "npm run check-format -- --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@vscode/python-environments": "^1.0.0",
    "@vscode/python-extension": "^1.0.5",
    "vscode-languageclient": "^9.0.1"
  }
}
